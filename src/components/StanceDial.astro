---
import type { StanceCategory } from '../styles/colors';

interface Props {
  counts: Record<StanceCategory, number>;
  total: number;
  label: string;
}

const { counts, total, label } = Astro.props;

const forCount = (counts['cosponsor'] || 0) + (counts['publicly-supports'] || 0) + (counts['leaning-support'] || 0);
const againstCount = (counts['publicly-opposes'] || 0) + (counts['leaning-oppose'] || 0);
const undecided = total - forCount - againstCount;

// Percentage of TOTAL who are "for" (conservative — silent doesn't count)
const forPct = total > 0 ? (forCount / total) * 100 : 0;

// Needle position based on proportion of total
// -90 = left (0%), 0 = center (50%), +90 = right (100%)
const needleAngle = total > 0 ? ((forCount / total) * 180) - 90 : -90;

// SVG arc parameters
const cx = 150;
const cy = 120;
const r = 90;

// Proportional arc segments (against on left, silent in middle, for on right)
// Angles go from -90deg (left) to +90deg (right) on the semicircle
const againstPct = total > 0 ? againstCount / total : 0;
const undecidedPct = total > 0 ? undecided / total : 1;
const forFrac = total > 0 ? forCount / total : 0;

// Convert fractions to angles on the semicircle (0 = left, PI = right)
// Order: for (left/green) -> undecided (middle/gray) -> against (right/red)
const forEnd = forFrac * Math.PI;
const undecidedEnd = (forFrac + undecidedPct) * Math.PI;

// Helper to get point on arc at a given angle (0 = left end, PI = right end)
function arcPoint(angle: number) {
  // Map 0..PI to the semicircle (left to right)
  const x = cx + r * Math.cos(Math.PI - angle);
  const y = cy - r * Math.sin(Math.PI - angle);
  return { x, y };
}

// Arc segment endpoints
const leftEnd = arcPoint(0);
const forArcEnd = arcPoint(forEnd);
const undecidedArcEnd = arcPoint(undecidedEnd);
const rightEnd = arcPoint(Math.PI);

// Large-arc flag: 1 if segment spans > 180deg (> half circle)
const forLarge = forFrac > 0.5 ? 1 : 0;
const undecidedLarge = undecidedPct > 0.5 ? 1 : 0;
const againstLarge = againstPct > 0.5 ? 1 : 0;
---

<div class="dial-wrap">
  <h3 class="dial-label">{label}</h3>
  <div class="dial">
    <svg viewBox="0 0 300 190" class="dial-svg">
      <!-- For arc (green — left) -->
      {forCount > 0 && (
        <path
          d={`M ${leftEnd.x} ${leftEnd.y} A ${r} ${r} 0 ${forLarge} 1 ${forArcEnd.x} ${forArcEnd.y}`}
          fill="none"
          stroke="#34a853"
          stroke-width="24"
          opacity="0.5"
        />
      )}

      <!-- Undecided arc (gray — middle) -->
      {undecided > 0 && (
        <path
          d={`M ${forArcEnd.x} ${forArcEnd.y} A ${r} ${r} 0 ${undecidedLarge} 1 ${undecidedArcEnd.x} ${undecidedArcEnd.y}`}
          fill="none"
          stroke="#9e9e9e"
          stroke-width="24"
          opacity="0.25"
        />
      )}

      <!-- Against arc (red — right) -->
      {againstCount > 0 && (
        <path
          d={`M ${undecidedArcEnd.x} ${undecidedArcEnd.y} A ${r} ${r} 0 ${againstLarge} 1 ${rightEnd.x} ${rightEnd.y}`}
          fill="none"
          stroke="#d32f2f"
          stroke-width="24"
          opacity="0.5"
        />
      )}

      <!-- Needle -->
      <g transform={`rotate(${needleAngle}, ${cx}, ${cy})`}>
        <line
          x1={cx}
          y1={cy}
          x2={cx}
          y2={cy - r + 8}
          stroke="#e6edf3"
          stroke-width="2.5"
          stroke-linecap="round"
        />
        <circle cx={cx} cy={cy} r="6" fill="#e6edf3" />
        <circle cx={cx} cy={cy} r="3" fill="#0d1117" />
      </g>

      <!-- Labels -->
      <text x={cx - r + 5} y={cy + 35} class="dial-end-label" fill="#34a853">For</text>
      <text x={cx + r - 5} y={cy + 35} class="dial-end-label dial-end-right" fill="#d32f2f">Against</text>
    </svg>
  </div>

  <div class="dial-stats">
    <div class="dial-pct">{Math.round(forPct)}%</div>
    <div class="dial-pct-label">in favor</div>
  </div>

  <div class="dial-counts">
    <div class="dial-count dial-count--for">
      <span class="dial-count-num">{forCount}</span>
      <span class="dial-count-label">For</span>
    </div>
    <div class="dial-count dial-count--undecided">
      <span class="dial-count-num">{undecided}</span>
      <span class="dial-count-label">Undecided</span>
    </div>
    <div class="dial-count dial-count--against">
      <span class="dial-count-num">{againstCount}</span>
      <span class="dial-count-label">Against</span>
    </div>
  </div>
</div>

<style>
  .dial-wrap {
    text-align: center;
  }

  .dial-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .dial {
    position: relative;
    max-width: 280px;
    margin: 0 auto;
  }

  .dial-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .dial-end-label {
    font-size: 13px;
    font-weight: 600;
  }

  .dial-end-right {
    text-anchor: end;
  }

  .dial-stats {
    text-align: center;
    margin-top: -8px;
  }

  .dial-pct {
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .dial-pct-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .dial-counts {
    display: flex;
    justify-content: center;
    gap: var(--space-xl);
    margin-top: var(--space-sm);
  }

  .dial-count {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .dial-count-num {
    font-size: 1.3rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .dial-count-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .dial-count--for .dial-count-num {
    color: #34a853;
  }

  .dial-count--against .dial-count-num {
    color: #d32f2f;
  }

  .dial-count--undecided .dial-count-num {
    color: #9e9e9e;
  }
</style>
