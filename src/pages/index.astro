---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <section class="wip-banner">
    <div class="container">
      <h1 class="wip-title">Work in Progress</h1>
      <p class="wip-text">
        This site aims to track where every member of Congress stands on impeachment.
        However, the stance data is currently generated using automated sentiment analysis
        that has proven inaccurate enough to be misleading. I'm working on improving
        the data quality before making this broadly available.
      </p>
      <p class="wip-text">
        In the meantime, the contact information and call scripts are accurate — if you
        know where your rep stands, you can still use this site to find their number and call.
      </p>
      <a href="/wip" class="wip-link">View work-in-progress site &rarr;</a>
    </div>
  </section>
</BaseLayout>

<style>
  .wip-banner {
    padding: var(--space-3xl) 0;
    text-align: center;
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .wip-title {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-lg);
  }

  .wip-text {
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    max-width: 640px;
    margin: 0 auto var(--space-md);
    line-height: 1.7;
  }

  .wip-link {
    display: inline-block;
    margin-top: var(--space-lg);
    padding: 0.75rem 1.5rem;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-weight: 500;
    font-size: 0.95rem;
  }

  .wip-link:hover {
    background: var(--color-bg-elevated);
    text-decoration: none;
  }
</style>
